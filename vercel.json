{
  "version": 2,
  "name": "pharma-webcast-frontend",
  "builds": [
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ],
  "env": {
    "BACKEND_API_URL": "https://your-backend-app.onrender.com"
  }
}